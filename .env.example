# OS-Agent 环境变量配置模板 一切以API文档为准
# 复制此文件为 .env 并填写实际值

# ============================================================
# API 配置（必需）
# ============================================================
# API 密钥
OPENAI_API_KEY=sk-proj-1234567890
# API 地址
OPENAI_API_BASE=https://api.openai.com/v1

# ============================================================
# 模型配置 
# ============================================================
# LLM 模型名称，常见：
# - deepseek/deepseek-chat
# - openai/gpt-4o
# - openai/gpt-4-turbo
# - anthropic/claude-3-5-sonnet
MODEL_NAME=deepseek/deepseek-chat

# 评估模块专用模型（可选，未设置则使用 MODEL_NAME）
# EVAL_MODEL_NAME=deepseek/deepseek-chat

# 评估时是否启用 JSON Output（DeepSeek 支持，若工具调用异常可设为 false）
# EVAL_USE_JSON_MODE=true

# ============================================================
# 仓库配置（必需）
# ============================================================
# 要分析的 OS 仓库 Git 地址
REPO_URL=https://github.com/example/os-project.git

# ============================================================
# 评估增强配置（新增 - 鲁棒性与重试）
# ============================================================

# 请求超时时间（秒，默认 300）
EVAL_REQUEST_TIMEOUT=300

# 最大重试次数（默认 3，可根据网络情况调整）
# EVAL_MAX_RETRIES=3

# 初始退避时间（秒，默认 2）
# EVAL_INITIAL_BACKOFF=2

# 最大退避时间（秒，默认 60）
# EVAL_MAX_BACKOFF=60

# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
# DEBUG: 详细调试信息，INFO: 常规信息，WARNING: 警告
LOG_LEVEL=INFO

# 是否启用详细日志（同时输出到文件和控制台，默认 false）
# VERBOSE_LOGGING=true

# 是否保存失败时的完整上下文（用于调试，默认 true）
# SAVE_FAILURE_CONTEXT=true
