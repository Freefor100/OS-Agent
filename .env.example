# OS-Agent 环境变量配置模板 一切以API文档为准
# 复制此文件为 .env 并填写实际值

# ============================================================
# API 配置（必需）
# ============================================================
# API 密钥
OPENAI_API_KEY=sk-proj-1234567890
# API 地址
OPENAI_API_BASE=https://api.openai.com/v1

# ============================================================
# 分析比对候选库配置 (OS-Agent C) (可选)
# ============================================================
# 当执行粗筛时，限定历史 OS 库扫描的列表，支持直接填入完整的 Git URL 或仓库名
# 例如: {https://gitlab.eduxiji.net/educg-group-36002-2710490/starry-mix, rcore-v3}
# HISTORY_PROJECTS={https://gitlab.eduxiji.net/educg-group-36002-2710490/starry-mix, rcore-v3}
#
# 当执行精比比对时，强制比对的目标列表，同样支持 URL 或短名称混合使用
# 例如: {https://gitlab.eduxiji.net/educg-group-36002-2710490/starry-mix, rcore-v3}
# COMPARE_CANDIDATES={https://gitlab.eduxiji.net/educg-group-36002-2710490/starry-mix, rcore-v3}

# ============================================================
# 模型配置 
# ============================================================
# LLM 模型名称，常见：
# - deepseek/deepseek-chat
# - openai/gpt-4o
# - openai/gpt-4-turbo
# - anthropic/claude-3-5-sonnet
MODEL_NAME=deepseek/deepseek-chat

# Describe / JSON-QA：单次回复 max_tokens（OpenAI 兼容字段；题多、证据长时建议 8192~32768，按服务商上限调整）
# DESCRIBE_MAX_OUTPUT_TOKENS=16384

# Describe：JSON-QA 校验成功后无工具 LLM 审计（题单+覆写前 JSON；不含 01/10；见 README）
# DESCRIBE_STAGE_REVIEW=0
# DESCRIBE_REVIEW_MODEL=

# ============================================================
# OS-Agent D Multi-Agent（可选，默认关闭）
# ============================================================
# 0 = 使用现有串行 Plan→Execute→Review 流水线；
# 1 = 使用 Multi-Agent 图模式，并启用下方并行/断点/任务级调度参数。
OS_AGENT_D_MULTI_AGENT=0

# 仅 Multi-Agent 模式生效。02-09 + 10_history 最多同时执行几个 stage；
# 01_overview 始终等待前置 stage 完成后串行执行。
OS_AGENT_MAX_PARALLEL_STAGES=2

# 单个 stage 内最多同时执行几个 task。
OS_AGENT_MAX_PARALLEL_TASKS_PER_STAGE=3

# 全局 LLM API 并发上限；不是 stage/task 并行数的乘积。
OS_AGENT_MAX_PARALLEL_LLM_CALLS=2

# 全局 LSP/RAG 并发上限；RAG 索引构建和 LSP target 切换仍会互斥。
OS_AGENT_MAX_PARALLEL_LSP_TASKS=1
OS_AGENT_MAX_PARALLEL_RAG_TASKS=3

# Review 失败后的补证据/局部重写轮次，以及单 task 重试次数。
OS_AGENT_MAX_REVIEW_FIX_ROUNDS=2
OS_AGENT_MAX_TASK_RETRIES=2

# v2: Plan Agent 生成 grouped task_plan；Task Agent 使用 LLM ReAct 查证据并产草稿答案。
# OS_AGENT_TASK_PLANNER_MODE: llm_fallback / llm_only / rule
# OS_AGENT_TASK_AGENT_MODE: react / react_only / tool
OS_AGENT_TASK_PLANNER_MODE=llm_fallback
OS_AGENT_TASK_AGENT_MODE=react
OS_AGENT_MAX_QUESTIONS_PER_TASK=4
OS_AGENT_MAX_TASKS_PER_STAGE_TOTAL=80
OS_AGENT_TASK_AGENT_MAX_STEPS=10
OS_AGENT_TASK_OUTPUT_MODE=evidence_and_draft
OS_AGENT_STAGE_WRITER_MODE=assembler

# 可选：逗号分隔强制重跑指定 stage（例如 08_network），默认留空。
# OS_AGENT_FORCE_STAGES=

# Multi-Agent 终端输出：compact / verbose / silent。
# Dashboard 暂缓实现。
OS_AGENT_TERMINAL_MODE=compact
OS_AGENT_EVENT_PREVIEW_CHARS=180

# ============================================================
# web_search 配置（可选，默认关闭）
# 仅用于比赛背景、赛道定位、目标要求和公开技术背景，不得用于判断源码实现事实
# ============================================================
# ENABLE_WEB_SEARCH=false
# TAVILY_API_KEY=
# SERPER_API_KEY=

# ============================================================
# 仓库配置（必需）
# ============================================================
# 要分析的 OS 仓库地址
REPO_URL=https://github.com/example/os-project.git

# Call Graph：缓存随 compile 配置/git/管线指纹自动失效；语义过滤需 pip install clang + 系统 libclang
# （无 Call Graph 专用环境变量）

# ============================================================
# 可选：调试与日志
# ============================================================

# 日志级别（DEBUG, INFO, WARNING, ERROR, CRITICAL）
# DEBUG: 详细调试信息，INFO: 常规信息，WARNING: 警告
# LOG_LEVEL=INFO

# 是否启用详细日志（同时输出到文件和控制台，默认 false）
# VERBOSE_LOGGING=true

# 是否保存失败时的完整上下文（用于调试，默认 true）
# SAVE_FAILURE_CONTEXT=true

# ============================================================
# Hugging Face（代码嵌入 / RAG，可选）
# ============================================================
# HF_ENDPOINT 未设置 → 默认国内镜像（https://hf-mirror.com，可用 OS_AGENT_HF_ENDPOINT 改基址）。
# HF_ENDPOINT 在 .env 里写了什么就用什么（写官方即官方，写镜像即镜像），例如：
# HF_ENDPOINT=https://huggingface.co

HF_ENDPOINT=https://hf-mirror.com 
# 不要默认镜像、且连 HF_ENDPOINT 都不想设时：
# OS_AGENT_USE_HF_MIRROR=false
# 仅改「默认镜像」的域名（仍仅在 HF_ENDPOINT 为空时生效）：
# OS_AGENT_HF_ENDPOINT=https://hf-mirror.com
# 嵌入模型 ID 或本地目录（默认 jinaai/jina-embeddings-v2-base-code）：
# CODE_EMBEDDING_MODEL=jinaai/jina-embeddings-v2-base-code
#
# 代码 RAG 建索引（core/code_rag.build_index）：encode 批大小。显存小（如 4GB 笔记本 GPU）
# 时出现 CUDA OOM，可调小（如 2、4）；默认 8；仅影响建库速度与峰值显存，不改变切块逻辑。
# CODE_EMBEDDING_ENCODE_BATCH=8
#
# 代码 RAG 检索（core/code_rag.search）：查询向量编码时使用的 SentenceTransformer prompt 名。
# 默认留空则与普通 encode 一致。部分模型（如 Qwen3-Embedding）文档建议在 query 侧使用
# prompt_name=query，此时可设为：CODE_EMBEDDING_QUERY_PROMPT_NAME=query
# （索引侧文档向量仍用默认 encode；若所用模型不支持该 prompt，可能报错，届时清空此项即可）
# CODE_EMBEDDING_QUERY_PROMPT_NAME=

# ============================================================
# KernelProject Agent D / Agent C 当前主线配置
# ============================================================

# Agent D 公开入口：
#   python agent_d.py --repo repos/xv6-riscv --repo-name xv6-riscv --ui
#   python agent_d.py --repo https://github.com/mit-pdos/xv6-riscv.git
#
# Agent C 公开入口：
#   python agent_c.py xv6-k210 xv6-riscv

# 产物根目录：Agent D 输出到 output/<repo>/_agent_d/
AGENT_OUTPUT_ROOT=output

# Agent D 必须使用 LLM。源码 evidence pack 是 LLM 深读输入的一部分。

# Thinking / reasoning。DeepSeek reasoner 可使用 thinking；不展示 CoT。
AGENT_D_THINKING=enabled
AGENT_D_REASONING_EFFORT=high
AGENT_D_STRICT_THINKING=true
AGENT_D_MAX_OUTPUT_TOKENS=32768
AGENT_D_CONTEXT_BUDGET_TOKENS=120000
AGENT_D_LLM_TIMEOUT_SECONDS=180
AGENT_D_LLM_RETRY_MAX=3

# 并发控制。节点批次由 core/kernel_tree.py 的 ANALYSIS_BATCHES_V2 定义；
# 同一批次内可并发，后续批次读取稳定 blackboard snapshot。
AGENT_D_NODE_CONCURRENCY=4
AGENT_D_LLM_CONCURRENCY=4
AGENT_D_LSP_CONCURRENCY=2
AGENT_D_EVIDENCE_CONCURRENCY=8
# 可选的应急内存保护，默认关闭；正常内存控制依靠完成节点立即落盘并驱逐。
# AGENT_D_MEMORY_SOFT_LIMIT_GB=8
AGENT_D_MEMORY_WAIT_SECONDS=20
AGENT_D_REPAIR_ROUNDS=2
# 单节点自主 ReAct 的最大步数。节点内消息只在本次运行存活，断点从节点边界恢复。
AGENT_D_REACT_MAX_STEPS=40

# LangGraph checkpoint / resume 与默认终端 Dashboard。
AGENT_D_AUTO_RESUME=true
AGENT_D_GRAPH_RECURSION_LIMIT=120
AGENT_D_TUI=true
AGENT_D_TUI_REFRESH_HZ=4
AGENT_D_TUI_MAX_ACTIVE_NODES=8
AGENT_D_TUI_EVENT_ROWS=8

# 调试：限制分析节点数，用于 smoke，不会跑全局 flow/dependency/consistency pass。
# AGENT_D_NODE_LIMIT=3

# Agent C 默认 corpus。命令行未传 corpus 时读取这里。
AGENT_C_CORPUS_REPOS=xv6-riscv,xv6-k210
